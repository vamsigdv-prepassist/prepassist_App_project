{
  "expo": {
    "name": "PrepAssist",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/brand-logo-new.png",
    "scheme": [
      "mobile",
      "com.googleusercontent.apps.848376794933-ic74b2ls913mpbvruirjt8jmda736fpq"
    ],
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/brand-logo-new.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8FAFC"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.prepassist.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "PrepAssist needs camera access to capture handwritten essays for AI evaluation.",
        "NSPhotoLibraryUsageDescription": "PrepAssist needs photo library access to upload essays and study materials."
      }
    },
    "android": {
      "package": "com.prepassist.mobile",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ],
      "intentFilters": [
        {
          "action": "android.intent.action.SEND",
          "data": [
            {
              "mimeType": "text/plain"
            }
          ],
          "category": [
            "android.intent.category.DEFAULT"
          ]
        },
        {
          "action": "android.intent.action.SEND",
          "data": [
            {
              "mimeType": "text/*"
            }
          ],
          "category": [
            "android.intent.category.DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "PrepAssist needs photo library access to upload your essays and study materials.",
          "cameraPermission": "PrepAssist needs camera access to capture handwritten essays for AI evaluation."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {
        "origin": "https://replit.com/"
      },
      "eas": {
        "projectId": "60c4c67d-9707-418a-9279-cb7c98034f58"
      }
    }
  }
}
